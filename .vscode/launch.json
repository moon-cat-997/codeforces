{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CF: debug (type input in terminal)",
            "type": "lldb",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${fileDirname}",
            "terminal": "integrated",
            "preLaunchTask": "C/C++: g++ build active file"
        },
        {
            "name": "CF: debug (stdin from tests/1.in)",
            "type": "lldb",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${fileDirname}",
            "stdio": [
                "${fileDirname}/tests/1.in",
                null,
                null
            ],
            "preLaunchTask": "C/C++: g++ build active file"
        },
        {
            "name": "CF: debug (pick a test)",
            "type": "lldb",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${fileDirname}",
            "stdio": [
                "${fileDirname}/tests/${input:testNumber}.in",
                null,
                null
            ],
            "preLaunchTask": "C/C++: g++ build active file"
        }
    ],
    "inputs": [
        {
            "id": "testNumber",
            "type": "promptString",
            "description": "Which tests/<n>.in to feed into stdin?",
            "default": "1"
        }
    ]
}
